# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
# Get these from your Supabase Project Settings > API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=travel-images

# Stripe Configuration
# Get these from your Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# Email (SMTP) Configuration
# Use Gmail App Password or other SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Travel App <noreply@travelapp.com>

# Redis Configuration
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Logging Configuration
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
LOG_DIR=./logs

# Cache TTL Configuration (in seconds)
CACHE_TTL_DESTINATIONS=600
CACHE_TTL_SEARCH=300
CACHE_TTL_ANALYTICS=300

# Auth Configuration
JWT_SECRET=your_jwt_secret_for_fallback
SESSION_SECRET=your_session_secret
